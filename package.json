{
  "name": "backend-assessment",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:packages": "npm run build --workspace=packages/proto && npm run build --workspace=packages/prisma",
    "build:user": "npm run build:packages && nest build user-service",
    "build:wallet": "npm run build:packages && nest build wallet-service",
    "start:user": "nest start user-service",
    "start:wallet": "nest start wallet-service",
    "start:user:dev": "nest start user-service --watch",
    "start:wallet:dev": "nest start wallet-service --watch",
    "db:migrate": "prisma migrate dev --schema=packages/prisma/schema.prisma",
    "db:generate": "prisma generate --schema=packages/prisma/schema.prisma"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.11.1",
    "@grpc/proto-loader": "^0.7.13",
    "@nestjs/common": "^10.4.1",
    "@nestjs/core": "^10.4.1",
    "@nestjs/microservices": "^10.4.1",
    "@nestjs/platform-express": "^10.4.1",
    "@prisma/client": "^5.19.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "nestjs-pino": "^4.1.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@types/node": "^22.5.5",
    "prisma": "^5.19.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  }
}
